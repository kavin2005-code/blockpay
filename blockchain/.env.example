# ─── BlockPay Blockchain .env ───────────────────────────
# Copy this file: cp .env.example .env
# Then fill in your real values before deploying to testnet.

# ── Local development (works out of the box with hardhat node) ──
# Leave PRIVATE_KEY blank to use Hardhat's built-in test account #0
PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# ── Polygon Mumbai Testnet ──
# Get a free RPC URL from https://alchemy.com or https://infura.io
POLYGON_MUMBAI_RPC_URL=https://rpc-mumbai.maticvigil.com

# ── Polygon Mainnet (production) ──
POLYGON_MAINNET_RPC_URL=https://polygon-rpc.com

# ── Ethereum Sepolia Testnet ──
SEPOLIA_RPC_URL=

# ── Block explorer verification (optional but recommended) ──
# Get free key at https://polygonscan.com/myapikey
POLYGONSCAN_API_KEY=
# Get free key at https://etherscan.io/myapikey
ETHERSCAN_API_KEY=

# ── Gas reporting (set to "true" to enable) ──
REPORT_GAS=
